# Supabase Configuration
# Get these values from your Supabase project settings (Project Settings > API)

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key (starts with "eyJ...")
# DO NOT use the service_role key or bucket key
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Comma-separated list of admin account emails.
ADMIN_EMAILS=you@example.com

# When true, guests can still send plain text messages.
ENABLE_UNREGISTERED=true
